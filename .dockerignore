.vscode/
.idea/
*.swp
*.swo
*~

# Archivos del sistema
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Cache
.cache/
__pycache__/

# Testing
coverage/
.nyc_output/

# Misc
*.bak
*.tmp
temp/